{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist/out-tsc",
    "sourceMap": true,
    "esModuleInterop": true,
    "declaration": false,
    "experimentalDecorators": true,
    "moduleResolution": "bundler",
    "importHelpers": true,
    "target": "ES2022",
    "module": "es2020",
    "paths": {
      "mdb-angular-ui-kit": [
        "./projects/mdb-angular-ui-kit"
      ],
      "mdb-angular-ui-kit/*": [
        "./projects/mdb-angular-ui-kit/*"
      ]
    },
    "useDefineForClassFields": false
  }
}